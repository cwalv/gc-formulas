.gc/
# Runtime-generated predicate fixtures (scenario drivers write these at run time).
# Static test fixtures (e.g. self-test-*.json) are tracked and should not be
# matched by this pattern.
fixtures/[0-9]*-expected.json

# ntm binary pre-built via assets/build-ntm.sh — not committed (size, platform-specific)
assets/ntm

# Python bytecode from the verifier (verify_bead_state.py) — local-only.
scripts/__pycache__/
